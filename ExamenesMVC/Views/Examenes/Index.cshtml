@using Examenes.Modelos.Enums
@model IEnumerable<Examenes.Modelos.Entidades.Examen>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Historial de Exámenes</h1>
        <a asp-action="Create" class="btn btn-primary shadow-sm">
            <i class="bi bi-plus-circle"></i> Nuevo Registro
        </a>
    </div>

    <div class="btn-group mb-4 shadow-sm" role="group">
        <a asp-action="Index" asp-route-tipo="@TipoExamen.Sangre"
           class="btn @(ViewBag.TipoActual == TipoExamen.Sangre ? "btn-danger" : "btn-outline-danger")">🩸 Sangre</a>

        <a asp-action="Index" asp-route-tipo="@TipoExamen.Orina"
           class="btn @(ViewBag.TipoActual == TipoExamen.Orina ? "btn-warning" : "btn-outline-warning")">🚽 Orina</a>

        <a asp-action="Index" asp-route-tipo="@TipoExamen.Heces"
           class="btn @(ViewBag.TipoActual == TipoExamen.Heces ? "btn-success" : "btn-outline-success")">💩 Heces</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>Fecha</th>
                        <th>Cédula Paciente</th>
                        <th>Nombre del Paciente</th>
                        <th class="text-center">Cant. Pruebas</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">No hay exámenes registrados en esta categoría.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>#@item.Id</strong></td>
                                <td>@item.Fecha.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.PacienteCedula</td>
                                <td>@(item.Paciente != null ? $"{item.Paciente.Nombre} {item.Paciente.Apellido}" : "Cargando...")</td>
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-secondary">@item.Resultados.Count</span>
                                </td>
                                <td class="text-end">
                                    <a asp-controller="Resultados" asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-sm btn-info text-white">
                                        Ver Reporte
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>